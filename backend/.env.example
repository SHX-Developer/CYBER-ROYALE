# Скопируй в .env и подставь свои значения.
DATABASE_URL="postgresql://cyber:cyber@localhost:5432/cyber_royale?schema=public"

# Telegram Bot Token (от @BotFather)
TELEGRAM_BOT_TOKEN=""

# Локальная разработка вне Telegram: 1 = логин фиктивным юзером,
# когда initData пустая. На проде должно быть 0.
DEV_AUTO_LOGIN="1"

# Порт API
PORT=3000
